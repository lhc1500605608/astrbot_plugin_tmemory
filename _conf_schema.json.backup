{
  "enable_auto_capture": {
    "type": "bool",
    "description": "自动采集用户消息",
    "hint": "开启后，每条用户消息会自动写入 conversation_cache，供后续定时蒸馏。",
    "default": true
  },
  "capture_assistant_reply": {
    "type": "bool",
    "description": "采集助手回复",
    "hint": "开启后，LLM 回复也会被采集到 conversation_cache。",
    "default": true
  },
  "enable_memory_injection": {
    "type": "bool",
    "description": "启用记忆注入",
    "hint": "在 on_llm_request 阶段将召回记忆追加到 system_prompt。",
    "default": true
  },
  "inject_memory_limit": {
    "type": "int",
    "description": "注入记忆条数上限",
    "hint": "每次请求最多注入多少条长期记忆。",
    "default": 5
  },
  "distill_interval_sec": {
    "type": "int",
    "description": "蒸馏间隔（秒）",
    "hint": "后台 worker 的轮询间隔。建议设置为 14400~21600（4~6 次/天），降低 token 消耗并提升蒸馏稳定性。",
    "default": 17280
  },
  "distill_min_batch_count": {
    "type": "int",
    "description": "最小蒸馏批量",
    "hint": "单用户未蒸馏消息达到该数量才触发蒸馏。建议 >= 12，兼顾质量与可触发性。",
    "default": 20
  },
  "distill_batch_limit": {
    "type": "int",
    "description": "单次蒸馏上限",
    "hint": "每次蒸馏最多处理多少条缓存消息。提高该值可减少蒸馏轮次。",
    "default": 80
  },
  "cache_max_rows": {
    "type": "int",
    "description": "缓存保留行数",
    "hint": "conversation_cache 超出后会触发规则摘要压缩，保留最近 N 行。",
    "default": 20
  },
  "memory_max_chars": {
    "type": "int",
    "description": "记忆最大字符数",
    "hint": "规则蒸馏 fallback 时单条记忆的最大长度。",
    "default": 220
  },
  "private_memory_in_group": {
    "type": "bool",
    "default": false,
    "description": "群聊中注入私聊记忆",
    "hint": "默认关闭。开启后群聊中也会注入该用户的私聊专属记忆，可能泄露隐私。"
  },
  "enable_vector_search": {
    "type": "bool",
    "default": false,
    "description": "启用向量检索",
    "hint": "开启后将启用向量检索能力，提升记忆召回质量。需要先安装 sqlite-vec: pip install sqlite-vec"
  },
  "embed_provider_id": {
    "type": "string",
    "default": "",
    "description": "Embedding 提供商 ID",
    "hint": "填写提供商 ID，如 openai, siliconflow, volc 等。"
  },
  "embed_model_id": {
    "type": "string",
    "default": "text-embedding-3-small",
    "description": "Embedding 模型名称",
    "hint": "例如 text-embedding-3-small, nomic-embed-text-v1.5"
  },
  "embed_dim": {
    "type": "int",
    "default": 1536,
    "description": "向量维度",
    "hint": "Embedding 模型的输出维度，需与模型一致。如 text-embedding-3-small 是 1536，bge-small-zh-v1.5 是 512"
  },
  "embed_base_url": {
    "type": "string",
    "default": "https://api.openai.com/v1",
    "description": "Embedding API Base URL",
    "hint": "OpenAI 兼容的 Embedding API 地址，支持自定义代理。"
  },
  "embed_api_key": {
    "type": "string",
    "default": "",
    "description": "Embedding API Key",
    "hint": "OpenAI 兼容的 API 鉴权密钥。",
    "obvious_hint": true
  },
  "vector_weight": {
    "type": "float",
    "default": 0.4,
    "description": "向量检索权重",
    "hint": "混合检索中向量相似度的权重（0~1）。1.0=纯向量，0.0=纯文本。"
  },
  "min_vector_sim": {
    "type": "float",
    "default": 0.15,
    "description": "最小向量相似度",
    "hint": "向量候选最低相似度阈值，(0~1)，低于阈值的结果会被过滤。"
  },
  "enable_reranker": {