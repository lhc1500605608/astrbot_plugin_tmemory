# =============================================================================
# tmemory + AstrBot Docker 环境变量模板
#
# 使用方式:
#   cp .env.example .env
#   编辑 .env 填入真实的 DEEPSEEK_API_KEY
#
# .env 已在 .gitignore 中排除，不会被提交到仓库。
# =============================================================================

# [必需] DeepSeek API Key
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# [可选] DeepSeek 模型（默认 deepseek-v4-flash）
# deepseek-v4-flash: 轻量快速模型，推荐日常使用
# deepseek-v4-pro[1m]: 顶配模型，带 1M 上下文窗口
DEEPSEEK_MODEL=deepseek-v4-flash

# [可选] DeepSeek API 地址（默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# [可选] 时区
TZ=Asia/Shanghai
